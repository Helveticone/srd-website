# ============================================================================
#  SR Delémont — Monorepo — Variables d'environnement
#  Copier ce fichier vers .env (à la racine) et .dev.vars (apps Cloudflare)
# ============================================================================

# ----------------------------------------------------------------------------
#  Base de données PostgreSQL (Drizzle)
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/srd"

# ----------------------------------------------------------------------------
#  Cloudflare Access (authentification des admins)
# ----------------------------------------------------------------------------
# Team domain : https://<team>.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN="srd.cloudflareaccess.com"
# Audience (AUD) tag de l'application Access — un par admin
CF_ACCESS_AUD_ASSOC="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CF_ACCESS_AUD_SA="yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"

# Secret JWT interne (différenciation de rôle assoc-admin / sa-admin)
JWT_SECRET="change-me-with-a-long-random-string"

# Bypass d'authentification en développement LOCAL uniquement (jamais en prod).
# Permet d'ouvrir un admin sans Cloudflare Access. Valeurs : assoc-admin | sa-admin
# À placer dans apps/admin-assoc/.env.local ou apps/admin-sa/.env.local
# SRD_DEV_ROLE="assoc-admin"

# ----------------------------------------------------------------------------
#  Cloudflare R2 (stockage médias : photos, vidéos)
# ----------------------------------------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_MEDIA="srd-media"
R2_PUBLIC_URL="https://media.srd.ch"

# ----------------------------------------------------------------------------
#  Cloudflare Images / Loader (optimisation next/image)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_CF_IMAGES_URL="https://srd.ch/cdn-cgi/image"

# ----------------------------------------------------------------------------
#  football.ch — widgets embed (résultats / classements live)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_FOOTBALL_CH_BASE="https://www.football.ch/sfv/Verband/Widgets.aspx"
NEXT_PUBLIC_WIDGET_1ERE_LIGUE="t-35976"
NEXT_PUBLIC_WIDGET_3E_LIGUE="t-35977"
NEXT_PUBLIC_WIDGET_FEMININE="t-43678"
NEXT_PUBLIC_WIDGET_4E_LIGUE="t-35978"
NEXT_PUBLIC_WIDGET_SENIORS_30="t-35979"

# ----------------------------------------------------------------------------
#  URLs publiques des apps
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://srd.ch"
NEXT_PUBLIC_ADMIN_ASSOC_URL="https://admin.srd.ch"
NEXT_PUBLIC_ADMIN_SA_URL="https://admin.pro.srd.ch"
